import("//build/ohos.gni")
import("//foundation/multimedia/av_codec/config.gni")

config("avc_encoder_public_cfg") {
  include_dirs = [
    "$av_codec_root_dir/services/engine/base/include",
    "$av_codec_root_dir/services/engine/codec/video/avcencoder",
    "$av_codec_root_dir/services/engine/codec/video/avcencoder/include",
    "$av_codec_root_dir/interfaces/inner_api/native",
  ]
}

ohos_shared_library("avc_encoder") {
  branch_protector_ret = "pac_ret"
  install_enable = true
  sanitize = av_codec_sanitize
  public_configs = [ ":avc_encoder_public_cfg" ]
  include_dirs = [
    "$av_codec_root_dir/services/dfx/include",
    "$av_codec_root_dir/services/engine/common/include",
    "$av_codec_root_dir/services/utils/include",
    "$av_codec_root_dir/services/engine/plugin/interface",
  ]

  defines = []
  defines += av_codec_defines

  if (!is_emulator && target_cpu == "arm64") {
    defines += [ "ARMV8" ]
  }

  sources = [
    "$av_codec_root_dir/services/engine/codec/video/avcencoder/avc_encoder.cpp",
    "$av_codec_root_dir/services/engine/codec/video/avcencoder/avc_encoder_api.cpp",
    "$av_codec_root_dir/services/engine/codec/video/avcencoder/avc_encoder_convert.cpp",
    "$av_codec_root_dir/services/engine/codec/video/avcencoder/avc_encoder_util.cpp",
  ]

  deps = [
    "$av_codec_root_dir/services/engine/base:av_codec_codec_base",
    "$av_codec_root_dir/services/engine/common:av_codec_engine_common",
  ]

  public_deps = [
    "$av_codec_root_dir/services/dfx:av_codec_service_dfx",
    "$av_codec_root_dir/services/utils:av_codec_service_utils",
  ]

  external_deps = [
    "bounds_checking_function:libsec_static",
    "c_utils:utils",
    "graphic_surface:surface",
    "graphic_surface:sync_fence",
    "hilog:libhilog",
    "hisysevent:libhisysevent",
    "hitrace:hitrace_meter",
    "init:libbegetutil",
    "media_foundation:media_foundation",
  ]

  subsystem_name = "multimedia"
  part_name = "av_codec"

  if (build_variant != "user") {
    defines += [ "BUILD_ENG_VERSION" ]
  }
}
