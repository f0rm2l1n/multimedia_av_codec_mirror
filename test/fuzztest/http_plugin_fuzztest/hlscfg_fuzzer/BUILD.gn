#####################hydra-fuzz###################
import("//build/config/features.gni")
import("//build/test.gni")
module_output_path = "av_codec/av_codec"
MEDIA_ROOT_DIR = "//foundation/multimedia/av_codec"

##############################fuzztest##########################################
ohos_fuzztest("HlsCfgFuzzTest") {
  module_out_path = module_output_path
  fuzz_config_file = "$MEDIA_ROOT_DIR/test/fuzztest/http_plugin_fuzztest/hlscfg_fuzzer"
  include_dirs = [
    "$MEDIA_ROOT_DIR/test/fuzztest/http_plugin_fuzztest/common",
    "$MEDIA_ROOT_DIR/services/media_engine/plugins/source/http_source",
    "$MEDIA_ROOT_DIR/services/media_engine/plugins/source/http_source/http",
    "$MEDIA_ROOT_DIR/interfaces",
    "$MEDIA_ROOT_DIR/interfaces/inner_api/native",
    "$MEDIA_ROOT_DIR/services/media_engine/plugins/source/http_source/base64",
    "$MEDIA_ROOT_DIR/services/media_engine/plugins/source/http_source/xml",
    "$MEDIA_ROOT_DIR/services/media_engine/plugins/source/http_source/hls",
    "$MEDIA_ROOT_DIR/test/unittest/common",
  ]
  cflags = [
    "-g",
    "-O0",
    "-Wno-unused-variable",
    "-fno-omit-frame-pointer",
  ]
  sources = [
    "hlscfg_fuzzer.cpp",
    "$MEDIA_ROOT_DIR/test/unittest/common/http_server_demo.cpp",
    "$MEDIA_ROOT_DIR/test/fuzztest/http_plugin_fuzztest/common/http_server_mock.cpp",
  ]

  external_deps = [
    "c_utils:utils",
    "ffmpeg:libohosffmpeg",
    "hilog:libhilog",
    "ipc:ipc_single",
    "media_foundation:native_media_core",
    "media_foundation:media_foundation",
    "window_manager:libwm",
    "graphic_surface:surface",
    "init:libbegetutil",
    "libxml2:libxml2",
    "openssl:libcrypto_shared",
    "safwk:system_ability_fwk",
    "netmanager_base:net_conn_manager_if",
  ]
  deps = [
    "$MEDIA_ROOT_DIR/services/media_engine/plugins/source/http_source:media_plugin_HttpSource",
    "$MEDIA_ROOT_DIR/services/dfx:av_codec_service_dfx",
  ]
  resource_config_file =
      "$MEDIA_ROOT_DIR/test/unittest/resources/ohos_test.xml"
}

###############################################################################
group("fuzztest") {
  testonly = true
  deps = []
  deps += [
    # deps file
    ":HlsCfgFuzzTest",  #引用测试套
  ]
}
###############################################################################
