import("//build/test.gni")
import("//foundation/multimedia/av_codec/config.gni")

MEDIA_ROOT_DIR = "//foundation/multimedia/av_codec/"
module_output_path = "av_codec/moduletest"

hwdecoder_moduletest_native_include_dirs = [
  "./include",
  "$MEDIA_ROOT_DIR/../../graphic/graphic_2d/frameworks/surface/include",
  "$MEDIA_ROOT_DIR/../../graphic/graphic_2d/interfaces/inner_api",
  "$MEDIA_ROOT_DIR/../../graphic/graphic_2d/interfaces/inner_api/surface",
  "$MEDIA_ROOT_DIR/../../graphic/graphic_2d/interfaces/inner_api/common",
  "$MEDIA_ROOT_DIR/interfaces/inner_api/native",
  "$MEDIA_ROOT_DIR/interfaces/kits/c",
  "$MEDIA_ROOT_DIR/../../../third_party/openssl/ohos_lite/include",
]

hwdecoder_moduletest_cflags = [
  "-std=c++17",
  "-fno-rtti",
  "-fno-exceptions",
  "-Wall",
  "-fno-common",
  "-fstack-protector-strong",
  "-Wshadow",
  "-FPIC",
  "-FS",
  "-O2",
  "-D_FORTIFY_SOURCE=2",
  "-fvisibility=hidden",
  "-Wformat=2",
  "-Wdate-time",
  "-Werror",
  "-Wextra",
  "-Wimplicit-fallthrough",
  "-Wsign-compare",
  "-Wunused-parameter",
]

##################################################################################################################
ohos_unittest("hwdecoder_native_module_test") {
  module_out_path = module_output_path
  include_dirs = hwdecoder_moduletest_native_include_dirs
  include_dirs += [ "./" ]

  cflags = hwdecoder_moduletest_cflags

  if (multimedia_av_codec_support_codec) {
    sources = [
      "./src/api_test.cpp",
      #"./src/func_test.cpp",

      #"./src/perf_test.cpp",
      #"./src/reli_test.cpp",
      #"./src/state_test.cpp",

      #"./src/compatibility_test.cpp",
      "./src/videodec_ndk_sample.cpp",
    ]
  }

  deps = [
    "$MEDIA_ROOT_DIR/../../graphic/graphic_2d:libsurface",
    "$MEDIA_ROOT_DIR/../../graphic/graphic_2d/frameworks/surface:surface",
    "$MEDIA_ROOT_DIR/../../graphic/graphic_2d/rosen/modules/render_service_client:librender_service_client",
    "$MEDIA_ROOT_DIR/../../graphic/graphic_2d/utils:libgraphic_utils",
    "$MEDIA_ROOT_DIR/../../graphic/graphic_2d/utils:sync_fence",
    "$MEDIA_ROOT_DIR/../../window/window_manager/wm:libwm",
    "$MEDIA_ROOT_DIR/interfaces/inner_api/native:av_codec_client",
    "$MEDIA_ROOT_DIR/interfaces/kits/c:native_media_codecbase",
    "$MEDIA_ROOT_DIR/interfaces/kits/c:native_media_core",
    "$MEDIA_ROOT_DIR/interfaces/kits/c:native_media_vdec",
  ]
  external_deps = [
    "c_utils:utils",
    "hiviewdfx_hilog_native:libhilog",
    "ipc:ipc_core",
  ]
  resource_config_file =
      "$MEDIA_ROOT_DIR/test/moduletest/resources/ohos_test.xml"
}
