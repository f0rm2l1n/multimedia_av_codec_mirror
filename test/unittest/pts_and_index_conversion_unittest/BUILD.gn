import("//build/test.gni")
import("//foundation/multimedia/av_codec/config.gni")

module_output_path = "av_codec/AVCodec_Video/unittest"
pts_and_index_conversion_test_sources = [
  "$av_codec_root_dir/services/media_engine/modules/pts_index_conversion/pts_and_index_conversion.cpp",
  "$av_codec_root_dir/services/media_engine/modules/demuxer/type_finder.cpp",
  "$av_codec_root_dir/services/media_engine/modules/source/source.cpp",
]
config("pts_and_index_conversio_unit_test_cfg") {
  defines = [
    "HST_ANY_WITH_NO_RTTI",
    "MEDIA_OHOS",
    "TESTING",
  ]

  cflags = [
    "-Wno-sign-compare",
    "-fno-exceptions",
    "-fno-common",
    "-fstack-protector-all",
    "-Wshadow",
    "-FPIC",
    "-FS",
    "-O2",
    "-D_FORTIFY_SOURCE=2",
    "-Wformat=2",
    "-Wdate-time",
    "-Dprivate=public",
    "-Dprotected=public",
    "-Wno-unused-parameter",
  ]

  cflags_cc = [
    "-std=c++17",
    "-fno-rtti",
  ]

  include_dirs = [
    "$av_codec_root_dir/interfaces",
    "$av_codec_root_dir/interfaces/inner_api",
    "$av_codec_root_dir/interfaces/inner_api/native",
    "$av_codec_root_dir/services/media_engine/modules",
    "$av_codec_root_dir/services/media_engine/modules/demuxer",
    "$av_codec_root_dir/services/media_engine/modules/pts_index_conversion",
    "$av_codec_root_dir/test/unittest/common",
    "$av_codec_root_dir/test/unittest/pts_and_index_conversion_unittest",
    "$av_codec_root_dir/test/unittest/pts_and_index_conversion_unittest/mock",
  ]
}

#################################################################################################################
ohos_unittest("pts_and_index_conversion_unittest") {
  sanitize = av_codec_test_sanitize
  module_out_path = module_output_path
  testonly = true
  configs = [
    ":pts_and_index_conversio_unit_test_cfg",
    "$av_codec_root_dir/services/dfx:av_codec_service_log_dfx_public_config",
  ]
  sources = pts_and_index_conversion_test_sources +
            [ "pts_and_index_conversion_unittest.cpp" ]
  deps = [
    "$av_codec_root_dir/services/dfx:av_codec_service_dfx",
    "$av_codec_root_dir/services/engine/base:av_codec_codec_base",
  ]

  external_deps = [
    "c_utils:utils",
    "googletest:gmock",
    "googletest:gtest",
    "hilog:libhilog",
    "hisysevent:libhisysevent",
    "media_foundation:media_foundation",
  ]
  resource_config_file =
      "$av_codec_root_dir/test/unittest/resources/ohos_test.xml"
}
