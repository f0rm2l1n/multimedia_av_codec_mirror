import("//build/test.gni")
import("//foundation/multimedia/av_codec/config.gni")

module_output_path = "av_codec/AVCodec_Video/unittest"

codeclist_unittest_cflags = [
  "-std=c++17",
  "-fno-rtti",
  "-Wall",
  "-fno-common",
  "-fstack-protector-strong",
  "-Wshadow",
  "-FPIC",
  "-FS",
  "-O2",
  "-D_FORTIFY_SOURCE=2",
  "-fvisibility=hidden",
  "-Wformat=2",
  "-Wdate-time",
  "-Werror",
  "-Wextra",
  "-Wimplicit-fallthrough",
  "-Wsign-compare",
  "-Wno-unused-function",
  "-Wno-unused-parameter",
  "-Dprivate=public",
  "-Dprotected=public",
]

av_codec_capi_external_deps = [
  "av_codec:av_codec_client",
  "av_codec:capi_packages",
  "av_codec:native_media_vdec",
  "av_codec:native_media_venc",
  "bounds_checking_function:libsec_static",
  "cJSON:cjson",
  "c_utils:utils",
  "config_policy:configpolicy_util",
  "graphic_2d:libgraphic_utils",
  "graphic_2d:librender_service_client",
  "graphic_surface:surface",
  "graphic_surface:sync_fence",
  "hilog:libhilog",
  "hisysevent:libhisysevent",
  "hitrace:hitrace_meter",
  "hiview:libucollection_client",
  "init:libbegetutil",
  "ipc:ipc_single",
  "media_foundation:media_foundation",
  "media_foundation:native_media_core",
  "openssl:libcrypto_shared",
  "samgr:samgr_proxy",
]

av_codec_inner_external_deps = [
  "av_codec:av_codec_client",
  "bounds_checking_function:libsec_static",
  "cJSON:cjson",
  "c_utils:utils",
  "config_policy:configpolicy_util",
  "eventhandler:libeventhandler",
  "googletest:gmock_main",
  "graphic_2d:libgraphic_utils",
  "graphic_2d:librender_service_base",
  "graphic_2d:librender_service_client",
  "graphic_surface:surface",
  "graphic_surface:sync_fence",
  "hilog:libhilog",
  "hisysevent:libhisysevent",
  "hitrace:hitrace_meter",
  "hiview:libucollection_client",
  "init:libbegetutil",
  "ipc:ipc_single",
  "media_foundation:media_foundation",
  "media_foundation:native_media_core",
  "openssl:libcrypto_shared",
  "samgr:samgr_proxy",
]

group("event_manager_coverage_unit_test") {
  testonly = true
  deps = [
    ":instance_memory_calculator_coverage_unit_test",
    ":instance_memory_update_event_coverage_unit_test",
  ]
}

##################################################################################################################
ohos_unittest("instance_memory_update_event_coverage_unit_test") {
  sanitize = av_codec_test_sanitize
  module_out_path = module_output_path
  cflags = codeclist_unittest_cflags
  cflags_cc = cflags
  configs = [
    "$av_codec_root_dir/test/unittest/common:av_codec_inner_unit_test_config",
  ]

  include_dirs = [
    "./",
    "$av_codec_root_dir/test/unittest/common",
    "$av_codec_root_dir/test/unittest/sa_avcodec_test/mock/include",
    "$av_codec_root_dir/frameworks/native/capi/common",
    "$av_codec_root_dir/interfaces/kits/c",
    "$av_codec_root_dir/services/dfx/include",
    "$av_codec_root_dir/services/include",
    "$av_codec_root_dir/services/services/common/event_manager/event_handler/background_event_handler/",
    "$av_codec_root_dir/services/services/common/event_manager/event_handler/instance_memory_update_event_handler",
    "$av_codec_root_dir/services/services/sa_avcodec",
    "$av_codec_root_dir/services/services/sa_avcodec/ipc",
    "$av_codec_root_dir/services/services/sa_avcodec/server/include",
  ]
  defines = av_codec_defines

  sources = [
    "$av_codec_root_dir/services/services/common/event_manager/event_handler"+
    "/background_event_handler/background_event_handler.cpp",
    "$av_codec_root_dir/services/services/common/event_manager/event_handler/instance_memory_update_event_handler/instance_memory_update_event_handler.cpp",
    "$av_codec_root_dir/test/unittest/sa_avcodec_test/mock/avcodec_service_stub_mock.cpp",
    "$av_codec_root_dir/test/unittest/sa_avcodec_test/mock/codec_service_stub_mock.cpp",
    "$av_codec_root_dir/test/unittest/sa_avcodec_test/mock/codeclist_service_stub_mock.cpp",
    "$av_codec_root_dir/test/unittest/sa_avcodec_test/mock/mem_mgr_client_mock.cpp",
    "$av_codec_root_dir/test/unittest/sa_avcodec_test/mock/system_ability_mock.cpp",
    "$av_codec_root_dir/services/services/sa_avcodec/server/avcodec_server.cpp",
    "$av_codec_root_dir/services/services/sa_avcodec/server/avcodec_server_manager.cpp",
    "./instance_memory_update_event_coverage_unit_test.cpp",
  ]

  deps = [
    "$av_codec_root_dir/interfaces/inner_api/native:av_codec_client",
    "$av_codec_root_dir/interfaces/kits/c:capi_packages",
    "$av_codec_root_dir/services/dfx:av_codec_service_dfx",
  ]

  external_deps = av_codec_inner_external_deps

  resource_config_file =
      "$av_codec_root_dir/test/unittest/resources/ohos_test.xml"
}

