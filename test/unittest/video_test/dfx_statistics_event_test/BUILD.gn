import("//build/test.gni")
import("//foundation/multimedia/av_codec/config.gni")

event_handler_dir = "$av_codec_root_dir/services/services/common/event_manager"

ohos_unittest("video_codec_dfx_statics_event_test") {
  sanitize = av_codec_test_sanitize
  module_out_path = "av_codec/AVCodec_Video/unittest"

  include_dirs = [
    "$av_codec_root_dir/services/services/common/",
    "$av_codec_root_dir/services/services/common/event_manager",
    "$av_codec_root_dir/services/services/sa_avcodec/server/include/",
    "$av_codec_root_dir/interfaces/inner_api/native/",
    "$event_handler_dir/event_handler/statistics_event_handler",
  ]

  sources = [
    "$av_codec_root_dir/services/services/sa_avcodec/server/avcodec_server_manager.cpp",
    "$event_handler_dir/event_handler/statistics_event_handler/statistics_event_handler.cpp",
    "./dfx_statistics_event_test.cpp",
  ]

  deps = [ "$av_codec_root_dir/services/dfx:av_codec_service_dfx" ]

  external_deps = [
    "cJSON:cjson",
    "c_utils:utils",
    "hidumper:lib_dump_usage",
    "hisysevent:libhisysevent",
    "hisysevent:libhisyseventmanager",
    "init:libbegetutil",
    "media_foundation:media_foundation",
    "samgr:samgr_proxy",
  ]

  subsystem_name = "multimedia"
  part_name = "av_codec"
}
