import("//build/test.gni")
import("//foundation/multimedia/av_codec/config.gni")

ohos_unittest("video_codec_param_checker_test") {
  sanitize = av_codec_test_sanitize
  module_out_path = "av_codec/AVCodec_Video/unittest"

  include_dirs = [
    "./",
    "$av_codec_root_dir/interfaces/kits/c",
    "$av_codec_root_dir/interfaces/inner_api/native",
    "$av_codec_root_dir/test/unittest/video_test/codeclist_test",
    "$av_codec_root_dir/test/unittest/video_test/codeclist_test/capi",
  ]

  sources = [
    "$av_codec_root_dir/test/unittest/video_test/codeclist_test/capi/codeclist_capi_mock.cpp",
    "$av_codec_root_dir/test/unittest/video_test/codeclist_test/capi/codeclist_capi_mock_factory.cpp",
    "codec_param_checker_inner_test.cpp",
    "codec_param_checker_test.cpp",
  ]

  deps = [
    "$av_codec_root_dir/interfaces/inner_api/native:av_codec_client",
    "$av_codec_root_dir/interfaces/kits/c:capi_packages",
  ]

  external_deps = [
    "c_utils:utils",
    "media_foundation:media_foundation",
    "media_foundation:native_media_core",
  ]

  subsystem_name = "multimedia"
  part_name = "av_codec"
}
