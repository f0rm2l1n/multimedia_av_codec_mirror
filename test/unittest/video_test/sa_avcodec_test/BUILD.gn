import("//build/test.gni")
import("//foundation/multimedia/av_codec/config.gni")

module_output_path = "av_codec/AVCodec_Video/unittest"

av_codec_unittest_cflags = [
  "-std=c++17",
  "-fno-rtti",
  "-Wall",
  "-fno-common",
  "-fstack-protector-strong",
  "-Wshadow",
  "-FPIC",
  "-FS",
  "-O2",
  "-D_FORTIFY_SOURCE=2",
  "-fvisibility=hidden",
  "-Wformat=2",
  "-Wdate-time",
  "-Werror",
  "-Wextra",
  "-Wimplicit-fallthrough",
  "-Wsign-compare",
  "-Wno-unused-function",
  "-Wno-unused-parameter",
  "-Dprivate=public",
  "-Dprotected=public",
]

##################################################################################################################
ohos_unittest("video_sa_avcodec_unit_test") {
  sanitize = av_codec_test_sanitize
  module_out_path = module_output_path
  include_dirs = [
    "./",
    "./mock/include",
    "$av_codec_root_dir/test/unittest/common",
    "$av_codec_root_dir/interfaces/inner_api/native",
    "$av_codec_root_dir/services/dfx/include",
    "$av_codec_root_dir/services/include",
    "$av_codec_root_dir/services/services/sa_avcodec/server/include",
    "$av_codec_root_dir/services/services/sa_avcodec",
    "$av_codec_root_dir/services/services/sa_avcodec/ipc",
    "$av_codec_root_dir/services/services/common",
    "$av_codec_root_dir/services/services/common/event_manager/event_handler/background_event_handler/",
    "$av_codec_root_dir/services/engine/codeclist",
    "$av_codec_root_dir/services/engine/base/include",
    "$av_codec_root_dir/services/engine/codec/include/video",
    "$av_codec_root_dir/services/engine/codec/video/avcencoder",
    "$av_codec_root_dir/services/engine/codec/video/hevcdecoder",
    "$av_codec_root_dir/services/engine/codec/video/fcodec/include",
    "$av_codec_root_dir/services/engine/common/include",
    "$av_codec_root_dir/services/utils/include",
    "$av_codec_root_dir/services/media_engine/plugins/ffmpeg_adapter/common",
  ]

  defines = av_codec_defines

  sources = [
    "$av_codec_root_dir/services/engine/codec/video/avc_encoder_loader.cpp",
    "$av_codec_root_dir/services/engine/codec/video/fcodec_loader.cpp",
    "$av_codec_root_dir/services/engine/codec/video/hcodec_loader.cpp",
    "$av_codec_root_dir/services/engine/codec/video/hevc_decoder_loader.cpp",
    "$av_codec_root_dir/services/engine/codec/video/video_codec_loader.cpp",
    "$av_codec_root_dir/services/engine/codeclist/audio_codeclist_info.cpp",
    "$av_codec_root_dir/services/engine/codeclist/codec_ability_singleton.cpp",
    "$av_codec_root_dir/services/engine/codeclist/codeclist_builder.cpp",
    "$av_codec_root_dir/services/engine/codeclist/codeclist_dump.cpp",
    "$av_codec_root_dir/services/services/common/event_manager/event_handler/background_event_handler/background_event_handler.cpp",
    "$av_codec_root_dir/services/services/sa_avcodec/server/avcodec_server.cpp",
    "$av_codec_root_dir/services/services/sa_avcodec/server/avcodec_server_manager.cpp",
    "./mock/avcodec_service_stub_mock.cpp",
    "./mock/codec_service_stub_mock.cpp",
    "./mock/codeclist_service_stub_mock.cpp",
    "./mock/mem_mgr_client_mock.cpp",
    "./mock/system_ability_mock.cpp",
    "./sa_avcodec_unit_test.cpp",
  ]

  cflags = av_codec_unittest_cflags

  cflags_cc = cflags

  deps = [ "$av_codec_root_dir/services/dfx:av_codec_service_dfx" ]

  if (target_cpu == "arm64") {
    av_codec_path = "\"/system/lib64\""
  } else {
    av_codec_path = "\"/system/lib\""
  }
  defines += [ "AV_CODEC_PATH=${av_codec_path}" ]

  external_deps = [
    "c_utils:utils",
    "drivers_interface_codec:libcodec_proxy_4.0",
    "ffmpeg:libohosffmpeg",
    "googletest:gmock_main",
    "hilog:libhilog",
    "hisysevent:libhisysevent",
    "init:libbegetutil",
    "ipc:ipc_single",
    "media_foundation:media_foundation",
    "samgr:samgr_proxy",
  ]

  resource_config_file =
      "$av_codec_root_dir/test/unittest/resources/ohos_test.xml"
}
