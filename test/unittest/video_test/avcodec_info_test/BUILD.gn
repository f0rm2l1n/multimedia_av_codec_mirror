import("//build/test.gni")
import("//foundation/multimedia/av_codec/config.gni")

ohos_unittest("codeclist_avcodec_info_unit_test") {
  sanitize = av_codec_test_sanitize
  module_out_path = "av_codec/av_codec/unittest"

  include_dirs = [ "$av_codec_root_dir/interfaces/inner_api/native" ]

  sources = [ "avcodec_info_unit_test.cpp" ]

  deps = [ "$av_codec_root_dir/interfaces/inner_api/native:av_codec_client" ]

  external_deps = [ "c_utils:utils" ]

  subsystem_name = "multimedia"
  part_name = "av_codec"
}
