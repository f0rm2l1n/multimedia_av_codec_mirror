import("//build/ohos.gni")
import("//foundation/multimedia/av_codec/config.gni")

vcodec_unittest_cflags = [
  "-std=c++17",
  "-fno-rtti",
  "-fno-exceptions",
  "-Wall",
  "-fno-common",
  "-fstack-protector-strong",
  "-Wshadow",
  "-FPIC",
  "-FS",
  "-O2",
  "-D_FORTIFY_SOURCE=2",
  "-fvisibility=hidden",
  "-Wformat=2",
  "-Wdate-time",
  "-Werror",
  "-Wextra",
  "-Wimplicit-fallthrough",
  "-Wsign-compare",
  "-Wno-constant-conversion",
  "-Wno-unused-function",
  "-Wno-unused-parameter",
  "-Dprivate=public",
  "-Dprotected=public",
]

#################################################################################################################videodec
config("video_sample_config") {
  include_dirs = [
    "./../common/codec_buffer_info",
    "./../common/codec_buffer_queue",
    "./../common/data_producer/avcc_reader",
    "./../common/data_producer/base/",
    "./../common/utils",
    "./common/include",
    "./enviroment/include",
    "./sample/callback",
    "$av_codec_root_dir/test/unittest/common/common_mock/avmemory/capi",
    "$av_codec_root_dir/test/unittest/common/common_mock/avmemory",
    "$av_codec_root_dir/test/unittest/common/common_mock/surface/capi",
    "$av_codec_root_dir/test/unittest/common/common_mock/surface",
    "$av_codec_root_dir/test/unittest/common/common_mock/avformat/capi",
    "$av_codec_root_dir/test/unittest/common/common_mock/avformat",
    "$av_codec_root_dir/test/unittest/common/common_mock/avbuffer/capi",
