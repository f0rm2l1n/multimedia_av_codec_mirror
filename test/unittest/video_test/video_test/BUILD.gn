import("//build/test.gni")
import("//foundation/multimedia/av_codec/config.gni")

declare_args() {
    video_codec_demo_use_rosen_window = false
}

config("video_sample_config") {
  include_dirs = [
    "./capbilities/capbility_node/data_producer/bitstream_reader",
    "./capbilities/capbility_node/data_producer/data_producer_base",
    "./capbilities/capbility_node/data_producer/demuxer",
    "./capbilities/capbility_node/data_producer/raw_data_reader",
    "./capbilities/capbility_node/video_codec/video_codec",
    "./capbilities/capbility_node/video_codec/video_decoder",
    "./capbilities/capbility_node/video_codec/video_encoder",
    "./capbilities/sample_buffer_queue",
    "./capbilities/sample_window_manager",
    "./capbilities/sample_window_manager/window_wrapper/include",
    "./common/include",
    "./sample/base",
    "./sample/yuv_viewer",
    "./sample/decoder",
    "./sample/encoder",
    "./sample/helper/include",
    "$av_codec_root_dir",
    "$av_codec_root_dir/interfaces/kits/c",
    "$av_codec_root_dir/services/dfx/include",
  ]
}

ohos_source_set("video_sample") {
  sources = [
    "./capbilities/capbility_node/data_producer/bitstream_reader/bitstream_reader.cpp",
    "./capbilities/capbility_node/data_producer/data_producer_base/data_producer_base.cpp",
    "./capbilities/capbility_node/data_producer/demuxer/demuxer.cpp",
    "./capbilities/capbility_node/data_producer/raw_data_reader/rawdata_reader.cpp",
    "./capbilities/capbility_node/video_codec/video_codec/codec_callback.cpp",
    "./capbilities/capbility_node/video_codec/video_codec/video_codec_base.cpp",
    "./capbilities/capbility_node/video_codec/video_decoder/video_decoder.cpp",
    "./capbilities/capbility_node/video_codec/video_encoder/video_encoder.cpp",
    "./capbilities/sample_buffer_queue/sample_buffer_queue.cpp",
    "./capbilities/sample_window_manager/sample_window_manager.cpp",
    "./capbilities/sample_window_manager/window_wrapper/native_image_window_wrapper.cpp",
    "./capbilities/sample_window_manager/window_wrapper/window_wrapper.cpp",
    "./common/av_codec_sample_log.cpp",
    "./common/sample_utils.cpp",
    "./sample/base/sample_base.cpp",
    "./sample/base/video_sample_base.cpp",
    "./sample/decoder/video_decoder_sample.cpp",
    "./sample/encoder/video_encoder_sample.cpp",
    "./sample/helper/arg_checker.cpp",
    "./sample/helper/arg_parser.cpp",
    "./sample/helper/sample_helper.cpp",
    "./sample/yuv_viewer/yuv_viewer.cpp",
  ]

  deps = [ "$av_codec_root_dir/interfaces/kits/c:capi_packages" ]

  public_configs = [ ":video_sample_config" ]

  defines = [
    "AVCODEC_LOG_USE_NO_DICT_LOG",
    "SAMPLE_BUILD_TO_EXECUTOR",
  ]

  cflags = [
    "-std=c++17",
    "-fno-rtti",
    "-fno-exceptions",
    "-Wall",
    "-fno-common",
    "-fstack-protector-strong",
    "-Wshadow",
    "-FPIC",
    "-FS",
    "-O2",
    "-D_FORTIFY_SOURCE=2",
    "-Wformat=2",
    "-Wdate-time",
    "-Werror",
    "-Wextra",
    "-Wimplicit-fallthrough",
    "-Wsign-compare",
    "-Wunused-parameter",
  ]

  external_deps = [
    "c_utils:utils",
    "eventhandler:libeventhandler",
    "graphic_2d:libnative_image",
    "graphic_surface:surface",
    "hilog:libhilog",
    "hitrace:hitrace_meter",
    "init:libbegetutil",
    "ipc:ipc_single",
    "media_foundation:media_foundation",
    "media_foundation:native_media_core",
  ]

  if (video_codec_demo_use_rosen_window) {
    defines += [ "SAMPLE_USE_ROSEN_WINDOW" ]
    sources += [ "./capbilities/sample_window_manager/window_wrapper/rosen_window_wrapper.cpp" ]
    external_deps += [
      "access_token:libaccesstoken_sdk",
      "access_token:libnativetoken_shared",
      "access_token:libtoken_setproc",
      "graphic_2d:librender_service_base",
      "graphic_2d:librender_service_client",
      "window_manager:libwm",
    ]
  }

  subsystem_name = "multimedia"
  part_name = "av_codec"
}

ohos_executable("video_codec_demo") {
  sources = [ "./demo/video_codec_demo.cpp" ]

  deps = [ ":video_sample" ]

  external_deps = [
    "c_utils:utils",
    "hilog:libhilog",
    "ipc:ipc_single",
    "media_foundation:media_foundation",
    "media_foundation:native_media_core",
  ]

  subsystem_name = "multimedia"
  part_name = "av_codec"
}
