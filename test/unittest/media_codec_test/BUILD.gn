import("//build/test.gni")
import("//foundation/multimedia/av_codec/config.gni")

module_output_path = "av_codec/unittest"

media_codec_unittest_cflags = [
  "-std=c++17",
  "-fno-rtti",
  "-fexceptions",
  "-Wall",
  "-fno-common",
  "-fstack-protector-strong",
  "-Wshadow",
  "-FPIC",
  "-FS",
  "-O2",
  "-D_FORTIFY_SOURCE=2",
  "-fvisibility=hidden",
  "-Wformat=2",
  "-Wdate-time",
  "-Werror",
  "-Wextra",
  "-Wimplicit-fallthrough",
  "-Wsign-compare",
  "-Wunused-parameter",
  "-Dprivate=public",
  "-Dprotected=public",
]

#################################################################################################################videodec
ohos_unittest("media_codec_unit_test") {
  module_out_path = module_output_path
  include_dirs = [
    "./",
    "./sample",
    "$av_codec_root_dir/services/engine/codeclist",
    "$av_codec_root_dir/services/engine/base/include",
    "$av_codec_root_dir/services/media_engine/modules/codec",
    "$av_codec_root_dir/services/media_engine/modules/codec/video_adapter/base",
    "$av_codec_root_dir/interfaces/plugin",
    "$media_foundation_root_dir/interface",
    "$media_foundation_root_dir/interface/inner_api",
    "$media_foundation_root_dir/interface/inner_api/buffer",
    "$media_foundation_root_dir/interface/inner_api/meta",
  ]

  defines = av_codec_defines

  sources = [
    "$av_codec_root_dir/services/media_engine/modules/codec/media_codec.cpp",
    "$av_codec_root_dir/services/media_engine/modules/codec/video_adapter/base/hcodec_adapter_loader.cpp",
    "./media_codec_state_unit_test.cpp",
    "./sample/media_codec_sample.cpp",
  ]

  cflags = media_codec_unittest_cflags

  public_deps = [
    "$av_codec_root_dir/services/media_engine/modules/codec/video_adapter/base:av_codec_codec_base_adapter",
    "$av_codec_root_dir/services/utils:av_codec_service_utils",
    "$av_codec_root_dir/test/unittest/common:av_codec_inner_unit_test",
  ]

  deps = [
    "$av_codec_root_dir/services/engine/codeclist:av_codec_engine_codeclist",
    "$av_codec_root_dir/services/utils:av_codec_format",
  ]

  external_deps = [
    "c_utils:utils",
    "graphic_2d:surface",
    "graphic_2d:sync_fence",
    "hilog:libhilog",
    "histreamer:media_foundation_buffer",
    "memory_utils:libdmabufheap",
  ]
}
